# Configuração do backend OpenRest (copia para openrest.toml para personalizar).
bind = "0.0.0.0:3000"
database_path = "./openrest.db"
printer_output_path = "./receipts.txt"
terminal_label = "Terminal 1"
signing_key_path = "./openrest_signing.pem"

# Audit. Anulações são sempre registadas; cancelamentos são opcionais.
registar_cancelamentos = false

# Dia operacional (spec §57 "Data Lógica de Caixa"). `cutoff` é a hora a
# partir da qual o programa considera que estamos num novo Dia de
# facturação. Útil em estabelecimentos que fecham após a meia-noite — um
# café aberto até à 01:00 configura "02:00" para garantir que tudo o que
# entra antes desse instante fica imputado ao Dia anterior.
[business_day]
cutoff = "00:00"
tz_offset_minutes = 0

[company]
nif = "999999990"
legal_name = "OpenRest Demo, Lda."
trade_name = "OpenRest Demo"
address = "Rua de Exemplo, 1"
postal_code = "1000-001"
city = "Lisboa"
country = "PT"
share_capital_cents = 500000          # 5.000,00 EUR
registry_office = "Conservatória de Lisboa"
registry_number = "999999990"
software_certificate = "0000/AT"      # placeholder até certificação real
default_vat_rate = 1300               # basis points (13%)

# Comunicação de Séries à AT (web-service SOAP `SeriesWS`). Em ambiente de
# desenvolvimento usamos o endpoint de testes com o NIF/subutilizador
# públicos da AT (599999993/0037). Em produção: substituir tudo abaixo
# pelas credenciais reais e pela chave pública AT do ambiente prod.
[at_series]
endpoint = "https://servicos.portaldasfinancas.gov.pt:722/SeriesWSService"
username = "599999993/0037"
password = "testes1234"                # password de teste da AT
public_key_path = "./keys/at_test_public.pem"
# O endpoint :722 (teste) e :422 (produção) da AT exigem TLS mútuo. O
# certificado de cliente tem de ser emitido por "AT Issuing CA1" ou
# "DGITA Issuing CA1". Em produção: gera-se um certificado próprio no
# Portal das Finanças → Apoio ao Contribuinte → Webservices.
client_pfx_path = "./keys/at_test_client.pfx"
client_pfx_password = "TESTEwebservice"
# Número do certificado AT do software de facturação (0 = não aplicável,
# usado durante desenvolvimento e até certificação)
num_cert_sw_fatur = 0
